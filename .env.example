# =============================================================================
# Contact Verification Platform - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# --- Application -------------------------------------------------------
APP_ENV=development
DEBUG=true
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string

# --- Auth Tokens -------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (PostgreSQL) ---------------------------------------------
POSTGRES_USER=cvp_user
POSTGRES_PASSWORD=cvp_password
POSTGRES_DB=contact_verification
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cvp_user:cvp_password@db:5432/contact_verification

# --- Redis -------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- AI / Search APIs --------------------------------------------------
# Anthropic Claude API - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Serper API (Google Search) - https://serper.dev  (2,500 free searches/month)
SERPER_API_KEY=...

# --- CORS / Frontend ---------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting -----------------------------------------------------
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_PERIOD=60

# --- Verification Settings ---------------------------------------------
MAX_SEARCH_RESULTS=10
MAX_EVIDENCE_SOURCES=20
VERIFICATION_TIMEOUT_SECONDS=120

# --- Batch Processing --------------------------------------------------
# Maximum rows per CSV upload (prevents quota exhaustion on Serper free tier)
MAX_BATCH_SIZE=50
# Monthly Serper call budget — stops batch dispatch when reached (leaves 100-call buffer)
SERPER_MONTHLY_QUOTA=2400
