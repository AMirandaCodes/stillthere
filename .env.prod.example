# =============================================================================
# StillThere — Production Environment Variables
# Copy this file to .env.prod and fill in every value before deploying.
# .env.prod must NEVER be committed to version control.
# =============================================================================

# --- Application -------------------------------------------------------
APP_ENV=production
DEBUG=false

# Generate a cryptographically strong key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Startup will refuse to boot in production if this is the placeholder or < 32 chars.
SECRET_KEY=REPLACE_WITH_GENERATED_KEY

# --- Auth Tokens -------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (PostgreSQL) ---------------------------------------------
# Postgres is not port-exposed in docker-compose.prod.yml.
# These values must match what Postgres was initialised with.
# Changing them after first boot requires: docker compose down -v (destroys data).
POSTGRES_USER=cvp_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=contact_verification
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------
# Redis is not port-exposed in docker-compose.prod.yml (internal only).
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- AI / Search APIs --------------------------------------------------
# Startup will refuse to boot in production if either key is empty.
ANTHROPIC_API_KEY=sk-ant-...
SERPER_API_KEY=...

# --- CORS / Frontend ---------------------------------------------------
# JSON array of allowed origins. Must match your production domain exactly.
# Example: CORS_ORIGINS=["https://yourdomain.com"]
CORS_ORIGINS=["https://yourdomain.com"]

# --- Flower (Task Monitor) ---------------------------------------------
# Flower is bound to 127.0.0.1 in docker-compose.prod.yml.
# Access it via SSH tunnel: ssh -L 5555:127.0.0.1:5555 user@server
# These credentials protect the Flower web UI.
FLOWER_USER=admin
FLOWER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Rate Limiting -----------------------------------------------------
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_PERIOD=60

# --- Verification Settings ---------------------------------------------
MAX_SEARCH_RESULTS=10
MAX_EVIDENCE_SOURCES=20
VERIFICATION_TIMEOUT_SECONDS=120

# --- Batch Processing --------------------------------------------------
MAX_BATCH_SIZE=50
SERPER_MONTHLY_QUOTA=2400
